# multi-agent skill 环境配置模板
# 复制为 ~/.skills/multi-agent/.env 并填入实际值

# ── 必填 ──────────────────────────────────────────────────
LLM_API_KEY=your-api-key-here

# ── 可选（有默认值）──────────────────────────────────────
# LLM 服务地址（默认：Kimi）
LLM_BASE_URL=https://api.moonshot.cn/v1

# 使用的模型（默认：moonshot-v1-8k）
LLM_MODEL=moonshot-v1-8k

# API 风格：openai 或 anthropic（默认：openai）
LLM_API_STYLE=openai

# ── 支持的 LLM 服务 ────────────────────────────────────────
# Kimi:      LLM_BASE_URL=https://api.moonshot.cn/v1     LLM_MODEL=moonshot-v1-8k
# DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1   LLM_MODEL=deepseek-chat
# OpenAI:    LLM_BASE_URL=https://api.openai.com/v1     LLM_MODEL=gpt-4o
# Claude:    LLM_API_STYLE=anthropic                    LLM_MODEL=claude-3-5-sonnet-20241022
# Qwen:      LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
# Ollama:    LLM_BASE_URL=http://localhost:11434/v1     LLM_MODEL=llama3.2
